@model SoundFy.Models.Musica

@{
    ViewData["Title"] = "Criar Músicas";
}

<h1>Adicionar Músicas ao Álbum: @ViewBag.AlbumNome</h1>

<hr />

<div class="row">
    <div class="col-md-8">
        <form id="musicasForm" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div id="musicasContainer">
                <div class="musica-group mb-3">
                    <label class="control-label">Nome da Música</label>
                    <input name="NomeMusica" class="form-control" required />
                </div>
            </div>

            <input type="hidden" name="AlbumId" value="@ViewBag.AlbumId" />

            <button type="button" class="btn btn-outline-primary" onclick="adicionarMusica()">+ Adicionar outra música</button>
            <br /><br />

            <button type="submit" class="btn btn-success">Salvar Músicas</button>
            <a asp-controller="Album" asp-action="Details" asp-route-id="@ViewBag.AlbumId" class="btn btn-secondary ml-2">Voltar</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function adicionarMusica() {
            const container = document.getElementById('musicasContainer');
            const index = container.children.length;

            const novaMusica = document.createElement('div');
            novaMusica.classList.add('musica-group', 'mb-3');

            novaMusica.innerHTML = `
                <label class="control-label">Nome da Música</label>
                <input name="NomeMusica" class="form-control" required />
            `;

            container.appendChild(novaMusica);
        }
    </script>
}
