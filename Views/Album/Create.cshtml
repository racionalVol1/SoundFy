@model SoundFy.Models.Album

@{
    ViewData["Title"] = "Create";
}

<h1>Criar</h1>

<h4>Album</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NomeAlbum" class="control-label"></label>
                <input asp-for="NomeAlbum" class="form-control" />
                <span asp-validation-for="NomeAlbum" class="text-danger"></span>
            </div>      

            <br>

            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<br

<div>
    <a asp-action="Index">Votlar a lista de álbuns</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
