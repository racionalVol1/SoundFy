@model SoundFy.Models.Playlist

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar</h1>

<h4>Playlist</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="PlaylistId" />
            <div class="form-group">
                <label asp-for="NomePlaylist" class="control-label"></label>
                <input asp-for="NomePlaylist" class="form-control" />
                <span asp-validation-for="NomePlaylist" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Votlar a lista de playlists</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
