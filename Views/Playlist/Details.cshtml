@model SoundFy.Models.Playlist

@{
    ViewData["Title"] = "Details";
}

<h1>Detalhes</h1>

<div>
    <h4>Playlist</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NomePlaylist)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NomePlaylist)
        </dd>
    </dl>
</div>

<div>
    <h4>Músicas da playlist</h4>
    <hr />
    @if (Model.PlaylistMusicas != null && Model.PlaylistMusicas.Any())
    {
        <ul class="list-group">
            @foreach (var pm in Model.PlaylistMusicas)
            {
                <li class="list-group-item">
                    @pm.Musica?.NomeMusica
                </li>
            }
        </ul>
    }
    else
    {
        <p>Esta playlist ainda não possui músicas.</p>
    }
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.PlaylistId">Editar</a> |
    <a asp-action="Index">Votlar a lista de playlists</a>
</div>
