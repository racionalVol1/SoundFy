@model SoundFy.Models.Playlist

@{
    ViewData["Title"] = "Create";
}

<h1>Criar nova playlist</h1>

<h4>Playlist</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NomePlaylist" class="control-label"></label>
                <input asp-for="NomePlaylist" class="form-control" />
                <span asp-validation-for="NomePlaylist" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Escolha uma música</label>
                <select name="MusicaId" class="form-control" asp-items="ViewBag.MusicaId"></select>
                <span asp-validation-for="PlaylistMusicas" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
            using (Html.BeginForm("Pesquisar", "Home", FormMethod.Get)) {
            <div class="form-group">
                <label for="pesquisa">Pesquisar:</label>
                <input type="text" class="form-control" id="pesquisa" name="pesquisa" placeholder="Digite sua pesquisa">
            </div>
            <button type="submit" class="btn btn-primary">Pesquisar</button>
            }
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Votlar a lista de playlists</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
