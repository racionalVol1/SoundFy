@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewData["Title"] = "Registrar";
}

@using (Html.BeginForm("Registrar", "Registro", FormMethod.Post))
{
    <div class="telas-inicias">
        <h1>Registrar</h1>

        <div class="input-telas-inicias">
            <div class="mb-3">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" required />
            </div>

            <div class="mb-3">
                <label for="senha">Senha:</label>
                <input type="password" id="senha" name="senha" required />
            </div>

            <div class="mb-3">
                <label for="tipo">Tipo de Usuário:</label>
                <select id="tipo" name="tipo" required>
                    <option value="Ouvinte">Ouvinte</option>
                    <option value="Artista">Artista</option>
                </select>
            </div>

            <div class="botoes-telas-inicias">
                <button type="submit">Registrar</button>
                <a href="@Url.Action("Index", "Login")">Voltar</a>
            </div>
        </div>
    </div>

    @if (ViewBag.Mensagem != null)
    {
        <div class="alert alert-info mt-3" style="text-align:center;">
            <p>@ViewBag.Mensagem</p>
        </div>
    }
}
