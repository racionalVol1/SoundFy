@using (Html.BeginForm("Autenticar", "Login", FormMethod.Post))
{
    <h1>Login</h1>

    <div>
        <label for="email">Email:</label>
        <input type="email" id="email" name="email" required />
    </div>

    <div>
        <label for="senha">Senha:</label>
        <input type="password" id="senha" name="senha" required />
    </div>

    @* Exibe o captcha se necessário *@
    @if (ViewBag.ExibirCaptcha != null && ViewBag.ExibirCaptcha)
    {
        <div>
            <label for="captcha">Digite o código: <strong>@ViewBag.ValorCaptcha</strong></label>
            <input type="text" id="captcha" name="captcha" required />
        </div>
    }

    <button type="submit">Login</button>

    <a href="@Url.Action("Index", "Registro")">Registrar</a>
    <a href="@Url.Action("RecuperarConta")">Esqueceu a senha</a>

    @* Mensagem de erro ou aviso *@
    @if (ViewBag.Mensagem != null)
    {
        <div style="color: red;">
            <p>@ViewBag.Mensagem</p>
        </div>
    }

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensagem"]
        </div>
    }
}
