<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/CSS/site.css" asp-append-version="true" />
    <title>SoundFy</title>
</head>

@using (Html.BeginForm("Autenticar", "Login", FormMethod.Post))
{
    <div class="telas-inicias">

        <h1>Login</h1>

        <div class="input-telas-inicias">


            <div class="mb-4">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" required />
            </div>
            <div class="mb-4">
                <label for="senha">Senha:</label>
                <input type="password" id="senha" name="senha" required />
            </div>
            <div class="mb-4">
                <label for="captcha">Digite o código:</label>
                <span style="font-weight:bold; font-size:1.2em;">@ViewBag.Captcha</span>
                <a href="@Url.Action("AtualizarCaptcha", "Login")" style="margin-left:10px;">Atualizar</a>
                <input type="text" id="captcha" name="captcha" required maxlength="6" />
            </div>
            <div class="botoes-telas-inicias">
                <button type="submit">Login</button>
                <a href="@Url.Action("Index", "Registro")">Registrar</a>
                <a href="@Url.Action("RecuperarConta")">Esqueceu a senha</a>
            </div>

        </div>
    </div>


    @if (ViewBag.Mensagem != null)
    {
        <div style="color: red;">
            <p>@ViewBag.Mensagem</p>
        </div>
    }
    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensagem"]
        </div>
    }
}