@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Adicionar Música";
}

<h2>Adicionar Música</h2>

@if (ViewBag.Mensagem != null)
{
    <div class="alert alert-info">@ViewBag.Mensagem</div>
}

<form asp-action="CriarMusica" method="post" enctype="multipart/form-data" class="mt-3">

    <div class="mb-3">
        <label for="titulo" class="form-label">Título da música:</label>
        <input type="text" class="form-control" id="titulo" name="titulo" required />
    </div>

    <div class="mb-3">
        <label for="nomeArtista" class="form-label">Nome do artista:</label>
        <input type="text" class="form-control" id="nomeArtista" name="nomeArtista" required />
    </div>

    <div class="mb-3">
        <label for="genero" class="form-label">Gênero:</label>
        <input type="text" class="form-control" id="genero" name="genero" />
    </div>

    <div class="mb-3">
        <label for="ano" class="form-label">Ano de lançamento:</label>
        <input type="number" class="form-control" id="ano" name="ano" />
    </div>

    <div class="mb-3">
        <label for="nomeArquivo" class="form-label">Nome do arquivo:</label>
        <input type="text" class="form-control" id="nomeArquivo" name="nomeArquivo" required />
    </div>

    <div class="mb-3">
        <label for="arquivo" class="form-label">Música (MP3):</label>
        <input type="file" class="form-control" id="arquivo" name="arquivo" accept=".mp3" required />
    </div>

    <button type="submit" class="btn btn-primary">Adicionar</button>
</form>
