@{
    ViewBag.Title = "Adicionar Música";
}

<h2>Adicionar Música</h2>

@if (ViewBag.Mensagem != null)
{
    <div class="alert alert-info">@ViewBag.Mensagem</div>
}

<form asp-action="CriarMusica" method="post" enctype="multipart/form-data">
    <label>Titulo da musica:</label>
    <input type="text" name="titulo" required /><br />

    <label>Nome do artista:</label>
    <input type="text" name="nomeArtista" required /><br />

    <label>Genero:</label>
    <input type="text" name="genero" /><br />

    <label>Ano de lançamento:</label>
    <input type="number" name="ano" /><br />

    <label>Nome do arquivo:</label>
    <input type="text" name="nomeArquivo" required /><br />

    <label>Musica (MP3):</label>
    <input type="file" name="arquivo" accept=".mp3" required /><br />

    <button type="submit">Adicionar</button>
</form>
